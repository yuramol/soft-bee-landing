{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@4.14.1",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "lint:ci": "eslint src",
    "lint:fix": "eslint src --fix",
    "lint:strict": "eslint src/**/*.{js,jsx,ts,tsx}",
    "prettier": "prettier --write .",
    "lint:fix:all": "yarn lint:fix && yarn prettier",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "sb": "supabase",
    "sb:migra": "supabase migration",
    "sb:migra:new": "supabase migration new",
    "sb:migra:apply": "supabase migration up",
    "sb:db": "supabase db",
    "sb:db:test": "supabase db test",
    "sb:db:lint": "supabase db lint",
    "sb:db:types": "supabase gen types typescript --local | tail +1 > src/types/supabaseSchema.ts",
    "sb:fn": "supabase functions",
    "sb:fn:serve": "supabase functions serve --no-verify-jwt"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx}": [
      "bash -c 'eslint --fix \"$@\" || true' --",
      "prettier --write --ignore-unknown",
      "eslint",
      "prettier --check --ignore-unknown"
    ],
    "*.{json,html,css,md,mjs,cjs,yml,yaml}": [
      "prettier --check --ignore-unknown"
    ],
    ".prettierrc": [
      "prettier --check --ignore-unknown"
    ],
    ".prettierignore": [
      "prettier --check --ignore-unknown"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "0.10.2",
    "@supabase/supabase-js": "2.104.1",
    "@tailwindcss/container-queries": "0.1.1",
    "@tailwindcss/typography": "0.5.19",
    "@tanstack/react-query": "5.100.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "4.1.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.74.0",
    "shadcn": "^4.5.0",
    "swiper": "^14.0.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@tailwindcss/postcss": "4.2.4",
    "@types/node": "24.3.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-tailwindcss": "3.18.3",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.0.0-insiders.f7d2598",
    "supabase": "2.95.4",
    "tailwindcss": "4.2.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.0"
  }
}
